{
	"name": "svelte-excalidraw-app",
	"private": true,
	"description": "A full-stack whiteboard application built with SvelteKit, embedding Excalidraw's React component within a Svelte app to demonstrate cross-framework integration. Features user authentication, persistent workspaces saved to a server database, and lazy-loaded React rendering isolated from the Svelte runtime.",
	"version": "1.0.0",
	"author": "Nyasper",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:start": "docker compose up",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-vercel": "6.3.3",
		"@sveltejs/kit": "2.60.1",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@types/node": "^24",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "5.55.9",
		"svelte-check": "4.4.8",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@excalidraw/excalidraw": "^0.18.1",
		"better-auth": "~1.4.21",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"resend": "^6.12.3"
	}
}
