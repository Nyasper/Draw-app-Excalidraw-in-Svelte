# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Better Auth — base URL for OAuth callbacks, email verification, and password reset links.
# Required in production: set to your deployed domain (e.g., https://myapp.vercel.app).
# Must be a full URL with protocol, no trailing slash.
ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Resend
# https://resend.com/api-keys
RESEND_API_KEY=""
MY_DOMAIN=""

# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
